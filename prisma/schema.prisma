generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  token        String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Subject {
  id              String   @id @default(cuid())
  data            Bytes    // AES-256-GCM encrypted JSON: { name, descriptor }
  iv              Bytes
  isTroublemaker  Boolean  @default(false)
  notes           String?
  notesEncrypted  Bytes?
  notesIv         Bytes?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Floor {
  id             String   @id @default(cuid())
  name           String
  sortOrder      Int      @default(0)
  floorPlanImage String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  rooms          Room[]
}

model Room {
  id         String   @id @default(cuid())
  floorId    String
  name       String
  shape      String   @default("polygon")
  points     Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  floor      Floor    @relation(fields: [floorId], references: [id], onDelete: Cascade)

  @@index([floorId])
}

model Device {
  id             String   @id @default(cuid())
  clientKey      String   @unique
  name           String
  assignedRoomId String?
  lastSeenAt     DateTime?
  lastAudioLevel Float?
  previewImage   String?
  previewTakenAt DateTime?
  nameEncrypted  Bytes?
  nameIv         Bytes?
  previewData    Bytes?
  previewIv      Bytes?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model RoomReading {
  id         String   @id @default(cuid())
  roomId     String
  deviceId   String
  audioLevel Float
  createdAt  DateTime @default(now())
}

model SecurityAlert {
  id          String   @id @default(cuid())
  subjectId   String
  subjectName String
  deviceId    String?
  deviceName  String?
  roomId      String?
  note        String?
  faceImage   String?
  data        Bytes?
  iv          Bytes?
  createdAt   DateTime @default(now())
  clearedAt   DateTime?
}
