generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Subject {
  id        String   @id @default(cuid())
  data      Bytes    // AES-256-GCM encrypted JSON: { name, descriptor }
  iv        Bytes
  createdAt DateTime @default(now())
}

model RoomReading {
  id         String   @id  // matches Room.id from src/lib/rooms.ts
  audioLevel Float    @default(0)
  updatedAt  DateTime @updatedAt
}
