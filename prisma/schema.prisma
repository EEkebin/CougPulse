generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Subject {
  id              String   @id @default(cuid())
  data            Bytes    // AES-256-GCM encrypted JSON: { name, descriptor }
  iv              Bytes
  isTroublemaker  Boolean  @default(false)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Device {
  id             String   @id @default(cuid())
  clientKey      String   @unique
  name           String
  assignedRoomId String?
  lastSeenAt     DateTime?
  lastAudioLevel Float?
  previewImage   String?
  previewTakenAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model RoomReading {
  id         String   @id @default(cuid())
  roomId     String
  deviceId   String
  audioLevel Float
  createdAt  DateTime @default(now())
}

model SecurityAlert {
  id          String   @id @default(cuid())
  subjectId   String
  subjectName String
  deviceId    String?
  deviceName  String?
  roomId      String?
  note        String?
  faceImage   String?
  createdAt   DateTime @default(now())
  clearedAt   DateTime?
}
